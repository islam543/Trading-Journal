generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Trade {
  id         Int      @id @default(autoincrement())
  symbol     String
  type       String
  entryPrice Float
  exitPrice  Float?
  quantity   Float
  pnl        Float?
  status     String   @default("OPEN")
  notes      String?
  imageUrl   String?
  timestamp  DateTime @default(now())
}
