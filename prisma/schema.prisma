generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String?
  googleId     String?       @unique
  name         String?
  createdAt    DateTime      @default(now())
  trades       Trade[]
  settings     UserSettings?
}

model Trade {
  id             Int      @id @default(autoincrement())
  symbol         String
  type           String
  entryPrice     Float
  time           String?
  strategy       String?
  stopLoss       Float?
  takeProfit     Float?
  pnl            Float?
  confluenceTags Json     @default("[]")
  notes          String?
  imageUrl       String?
  timestamp      DateTime @default(now())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
}

model UserSettings {
  id                    Int     @id @default(autoincrement())
  userId                Int     @unique
  user                  User    @relation(fields: [userId], references: [id])
  theme                 String  @default("dark")
  dashboardWidgets      Json    @default("{\"metrics\":true,\"performance\":true,\"calendar\":true,\"goals\":true,\"recentActivity\":true,\"distribution\":true}")
  tradeCardVisibility   Json    @default("{\"entryPrice\":true,\"stopLoss\":true,\"takeProfit\":true,\"pnl\":true,\"strategy\":true,\"confluenceTags\":true,\"notes\":true,\"image\":true,\"time\":true}")
  themeIntensity        String  @default("medium")
}
